<%- include('_header', { pageTitle: 'Dashboard', activePage: 'dashboard' }) %>

<% if (usuario && usuario.perfil === 'admin') { %>
  <div style="margin-bottom: 20px; display: flex; justify-content: flex-end;">
    <a href="/User/cadastroUsuario" class="button">
      <span class="icon">👤+</span> Cadastrar Novo Usuário
    </a>
  </div>
<% } %>

<section class="stats-grid">
  <article class="stat-card">
    <p class="stat-card__label">Clientes</p>
    <h3><%= resumo.clientes %></h3>
  </article>
  <article class="stat-card">
    <p class="stat-card__label">Pratos</p>
    <h3><%= resumo.pratos %></h3>
  </article>
  <article class="stat-card">
    <p class="stat-card__label">Pedidos</p>
    <h3><%= resumo.pedidos %></h3>
  </article>
  <article class="stat-card">
    <p class="stat-card__label">Itens do Pedido</p>
    <h3><%= resumo.itensPedido %></h3>
  </article>
</section>

<section class="panel-grid">
  <article class="panel-card">
    <div class="panel-card__header">
      <h3>Pedidos recentes</h3>
      <a href="/painel/pedidos">Ver todos</a>
    </div>
    <% if (pedidosRecentes.length === 0) { %>
      <p class="empty-state">Nenhum pedido cadastrado ainda.</p>
    <% } else { %>
      <div class="stack-list">
        <% pedidosRecentes.forEach((pedido) => { %>
          <div class="stack-item">
            <div>
              <strong>Mesa <%= pedido.mesa %></strong>
              <p><%= pedido.cliente?.nome || 'Sem cliente vinculado' %></p>
            </div>
            <span class="chip"><%= pedido.status || 'sem status' %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>

  <article class="panel-card">
    <div class="panel-card__header">
      <h3>Cardápio</h3>
      <a href="/painel/pratos">Ver todos</a>
    </div>
    <% if (pratosDestaque.length === 0) { %>
      <p class="empty-state">Nenhum prato cadastrado ainda.</p>
    <% } else { %>
      <div class="stack-list">
        <% pratosDestaque.forEach((prato) => { %>
          <div class="stack-item">
            <div>
              <strong><%= prato.nome %></strong>
              <p><%= prato.categoria || 'Sem categoria' %></p>
            </div>
            <span class="price-tag">R$ <%= Number(prato.preco).toFixed(2) %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>
</section>

<%- include('_footer') %>

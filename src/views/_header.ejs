<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — Restaurante</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="brand">
      <p class="eyebrow">Painel</p>
      <h1 class="brand__title">Restaurante</h1>
    </div>
    <nav class="nav">
      <a class="nav__link <%= activePage === 'dashboard'   ? 'nav__link--active' : '' %>" href="/painel">Dashboard</a>
        <a class="nav__link <%= activePage === 'pedidos'     ? 'nav__link--active' : '' %>" href="/painel/pedidos">Pedidos</a>
      <a class="nav__link <%= activePage === 'clientes'    ? 'nav__link--active' : '' %>" href="/painel/clientes">Clientes</a>
      <a class="nav__link <%= activePage === 'pratos'      ? 'nav__link--active' : '' %>" href="/painel/pratos">Cardápio</a>
    
      <a class="nav__link <%= activePage === 'itensPedido' ? 'nav__link--active' : '' %>" href="/painel/itens-pedido">Itens do Pedido</a>
    </nav>
    <div class="sidebar__footer">
      <form action="/login/logout" method="post">
        <button class="button button--ghost button--full" type="submit">Sair</button>
      </form>
    </div>
  </aside>
  <main class="content">
    <header class="topbar">
      <h2 class="topbar__title"><%= pageTitle %></h2>
      <span class="topbar__user"><%= typeof usuario !== 'undefined' && usuario?.nome ? usuario.nome : '' %></span>
    </header>

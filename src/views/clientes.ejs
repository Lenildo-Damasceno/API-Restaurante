<%- include('./_header.ejs', { pageTitle: 'Clientes', activePage: 'clientes' }) %>

<% if (feedback) { %>
  <div class="feedback feedback--<%= feedback.tipo %>"><%= feedback.mensagem %></div>
<% } %>

<section class="form-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Novo</p>
      <h3>Cadastrar cliente</h3>
    </div>
  </div>
  <form class="form-grid" action="/painel/clientes" method="post">
    <label>
      <span>Nome *</span>
      <input type="text" name="nome" placeholder="Ex.: João Silva" required>
    </label>
    <label>
      <span>Telefone</span>
      <input type="text" name="telefone" placeholder="Ex.: 85999999999">
    </label>
    <div class="form-actions">
      <button class="button" type="submit">Cadastrar</button>
    </div>
  </form>
</section>

<section class="table-card">
  <% if (clientes.length === 0) { %>
    <p class="empty-state">Nenhum cliente cadastrado ainda.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% clientes.forEach((cliente) => { %>
            <tr>
              <td><strong><%= cliente.nome %></strong></td>
              <td><%= cliente.telefone || '—' %></td>
              <td class="actions">
                <button class="button button--small" data-id="<%= cliente.id %>" data-nome="<%= cliente.nome %>" data-telefone="<%= cliente.telefone || '' %>" onclick="abrirModalEditar(this)">Editar</button>
                <button class="button button--small button--danger" 
                        data-id="<%= cliente.id %>" 
                        data-nome="<%= cliente.nome %>" 
                        onclick="deletarCliente(this.dataset.id, this.dataset.nome)">Deletar</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<script>
function abrirModalEditar(button) {
  const id = button.getAttribute('data-id');
  const nome = button.getAttribute('data-nome');
  const telefone = button.getAttribute('data-telefone');
  const novoNome = prompt('Novo nome:', nome);
  if (!novoNome) return;
  const novoTelefone = prompt('Novo telefone:', telefone);
  if (novoTelefone === null) return;
  fetch(`/clientes/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ nome: novoNome, telefone: novoTelefone })
  }).then(res => { if (!res.ok) throw new Error('Erro ao atualizar'); return res.json(); })
    .then(() => { alert('Cliente atualizado!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}

function deletarCliente(id, nome) {
  if (!confirm(`Deletar "${nome}"?`)) return;
  fetch(`/clientes/${id}`, { method: 'DELETE' })
    .then(res => { if (!res.ok) throw new Error('Erro ao deletar'); return res.json(); })
    .then(() => { alert('Cliente deletado!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

<%- include('./_footer.ejs') %>

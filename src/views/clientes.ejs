<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>

<!-- Navegação -->
<section class="page-header">
  <div>
    <p class="eyebrow">Gestão de Dados</p>
    <h2>Clientes</h2>
    <p>Gerencie os clientes do seu restaurante.</p>
  </div>
  <div class="hero__actions">
    <a class="button" href="/painel">Dashboard</a>
    <a class="button" href="/painel/pratos">Cardápio</a>
    <a class="button" href="/painel/pedidos">Pedidos</a>
    <a class="button" href="/painel/itens-pedido">Itens do Pedido</a>
    <a class="button button--ghost" href="/status">Status</a>
  </div>
</section>

<!-- Feedback -->
<% if (feedback) { %>
  <section class="feedback feedback--<%= feedback.tipo %>"><%= feedback.mensagem %></section>
<% } %>

<!-- Formulário de Cadastro -->
<section class="form-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Novo</p>
      <h3>Cadastrar cliente</h3>
    </div>
  </div>

  <form class="form-grid" action="/painel/clientes" method="post">
    <label>
      <span>Nome *</span>
      <input type="text" name="nome" placeholder="Ex.: João Silva" required>
    </label>

    <label>
      <span>Telefone</span>
      <input type="text" name="telefone" placeholder="Ex.: 85999999999">
    </label>

    <div class="form-actions">
      <button class="button" type="submit">Cadastrar</button>
    </div>
  </form>
</section>

<!-- Tabela de Clientes -->
<section class="table-card">
  <% if (clientes.length === 0) { %>
    <p class="empty-state">Nenhum cliente cadastrado ainda.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% clientes.forEach((cliente) => { %>
            <tr>
              <td><strong><%= cliente.nome %></strong></td>
              <td><%= cliente.telefone || '—' %></td>
              <td class="actions">
                <button class="button button--small" data-id="<%= cliente.id %>" data-nome="<%= cliente.nome %>" data-telefone="<%= cliente.telefone || '' %>" onclick="abrirModalEditar(this)">Editar</button>
                <button class="button button--small button--danger" onclick="deletarCliente('<%= cliente.id %>', '<%= cliente.nome %>')">Deletar</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<script>
function abrirModalEditar(button) {
  const id = button.getAttribute('data-id');
  const nome = button.getAttribute('data-nome');
  const telefone = button.getAttribute('data-telefone');

  const novoNome = prompt('Novo nome:', nome);
  if (!novoNome) return;

  const novoTelefone = prompt('Novo telefone:', telefone);
  if (novoTelefone === null) return;

  atualizarCliente(id, novoNome, novoTelefone);
}

function atualizarCliente(id, nome, telefone) {
  fetch(`/clientes/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ nome, telefone })
  })
    .then(res => {
      if (!res.ok) throw new Error('Erro ao atualizar');
      return res.json();
    })
    .then(data => {
      alert('Cliente atualizado com sucesso!');
      location.reload();
    })
    .catch(err => alert('Erro: ' + err.message));
}

function deletarCliente(id, nome) {
  if (!confirm(`Tem certeza que deseja deletar "${nome}"?`)) return;

  fetch(`/clientes/${id}`, { method: 'DELETE' })
    .then(res => {
      if (!res.ok) throw new Error('Erro ao deletar');
      return res.json();
    })
    .then(data => {
      alert('Cliente deletado com sucesso!');
      location.reload();
    })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

</body>
</html>


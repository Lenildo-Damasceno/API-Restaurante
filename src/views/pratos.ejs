<%- include('./_header.ejs', { pageTitle: 'Cardápio', activePage: 'pratos' }) %>

<% if (feedback) { %>
  <div class="feedback feedback--<%= feedback.tipo %>"><%= feedback.mensagem %></div>
<% } %>

<section class="form-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Cadastro</p>
      <h3>Novo prato</h3>
    </div>
  </div>
  <form class="form-grid form-grid--three" action="/painel/pratos" method="post">
    <label>
      <span>Nome</span>
      <input type="text" name="nome" placeholder="Ex.: Lasanha da casa" required>
    </label>
    <label>
      <span>Categoria</span>
      <input type="text" name="categoria" placeholder="Ex.: Massas">
    </label>
    <label>
      <span>Preço</span>
      <input type="number" step="0.01" min="0" name="preco" placeholder="29.90" required>
    </label>
    <div class="form-actions">
      <button class="button" type="submit">Cadastrar prato</button>
    </div>
  </form>
</section>

<section class="cards-grid">
  <% if (pratos.length === 0) { %>
    <p class="empty-state">Nenhum prato cadastrado no banco.</p>
  <% } else { %>
    <% pratos.forEach((prato) => { %>
      <article class="menu-card">
        <p class="menu-card__category"><%= prato.categoria || 'Sem categoria' %></p>
        <h3><%= prato.nome %></h3>
        <p class="menu-card__price">R$ <%= Number(prato.preco).toFixed(2) %></p>
        <div class="actions">
          <button class="button button--small" 
                  data-id="<%= prato.id %>" 
                  data-nome="<%= prato.nome %>" 
                  data-categoria="<%= prato.categoria || '' %>" 
                  data-preco="<%= prato.preco %>" 
                  onclick="editarPrato(this.dataset.id, this.dataset.nome, this.dataset.categoria, this.dataset.preco)">Editar</button>
          <button class="button button--small button--danger" onclick="confirmarDelecao('/pratos/<%= prato.id %>', 'prato')">Deletar</button>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>

<script>
function confirmarDelecao(url, tipo) {
  if (!confirm(`Deletar este ${tipo}?`)) return;
  fetch(url, { method: 'DELETE' })
    .then(res => { if (!res.ok) throw new Error('Erro'); return res.json(); })
    .then(() => { alert('Deletado com sucesso!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}

function editarPrato(id, nome, categoria, preco) {
  const novoNome = prompt('Novo nome:', nome); if (novoNome === null) return;
  const novaCategoria = prompt('Nova categoria:', categoria); if (novaCategoria === null) return;
  const novoPreco = prompt('Novo preço:', preco); if (novoPreco === null) return;
  fetch(`/pratos/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ nome: novoNome, categoria: novaCategoria, preco: parseFloat(novoPreco) })
  }).then(res => { if (!res.ok) throw new Error('Erro'); return res.json(); })
    .then(() => { alert('Prato atualizado!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

<%- include('./_footer.ejs') %>

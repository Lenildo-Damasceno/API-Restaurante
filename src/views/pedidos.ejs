<%- include('_header', { pageTitle: 'Pedidos', activePage: 'pedidos' }) %>

<% if (feedback) { %>
  <div class="feedback feedback--<%= feedback.tipo %>"><%= feedback.mensagem %></div>
<% } %>

<section class="form-card">
  <div class="panel-card__header">
    <div>
      <p class="eyebrow">Cadastro rápido</p>
      <h3>Novo pedido</h3>
    </div>
  </div>
  <form class="form-grid" action="/painel/pedidos" method="post">
    <div class="form-row">
      <label>
        <span>Cliente</span>
        <select name="idCliente" required>
          <option value="">Selecione um cliente</option>
          <% clientes.forEach((cliente) => { %>
            <option value="<%= cliente.id %>"><%= cliente.nome %></option>
          <% }) %>
        </select>
      </label>
      <label>
        <span>Mesa</span>
        <input type="number" min="1" name="mesa" placeholder="1" required>
      </label>
      <label>
        <span>Prato pedido</span>
        <select name="idPrato" required>
          <option value="">Selecione um prato</option>
          <% pratos.forEach((prato) => { %>
            <option value="<%= prato.id %>"><%= prato.nome %></option>
          <% }) %>
        </select>
      </label>
      <div class="form-actions">
        <button class="button" type="submit">Criar pedido</button>
      </div>
    </div>
  </form>
</section>

<section class="cards-grid cards-grid--wide">
  <% if (pedidos.length === 0) { %>
    <p class="empty-state">Nenhum pedido cadastrado no banco.</p>
  <% } else { %>
    <% pedidos.forEach((pedido) => { %>
      <article class="order-card">
        <div class="order-card__top">
          <div>
            <p class="order-card__meta">Mesa <%= pedido.mesa %></p>
            <h3><%= pedido.cliente?.nome || 'Cliente não vinculado' %></h3>
          </div>
          <span class="chip"><%= pedido.status || 'sem status' %></span>
        </div>
        <p class="order-card__sub">Itens: <strong><%= pedido.itens.length %></strong></p>
        <% if (pedido.itens.length === 0) { %>
          <p class="empty-state empty-state--small">Sem itens neste pedido.</p>
        <% } else { %>
          <ul class="mini-list">
            <% pedido.itens.forEach((item) => { %>
              <li>
                <span><%= item.prato?.nome || 'Prato removido' %></span>
                <strong>x<%= item.quantidade %></strong>
              </li>
            <% }) %>
          </ul>
        <% } %>
        <div class="actions">
          <button class="button button--small" onclick="editarPedido('<%= pedido.id %>', '<%= pedido.mesa %>', '<%= pedido.status || '' %>')">Editar</button>
          <button class="button button--small button--danger" onclick="confirmarDelecao('/pedidos/<%= pedido.id %>', 'pedido')">Deletar</button>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>

<script>
function confirmarDelecao(url, tipo) {
  if (!confirm(`Deletar este ${tipo}?`)) return;
  fetch(url, { method: 'DELETE' })
    .then(res => { if (!res.ok) throw new Error('Erro'); return res.json(); })
    .then(() => { alert('Deletado!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}

function editarPedido(id, mesa, status) {
  const novaMesa = prompt('Nova mesa:', mesa); if (novaMesa === null) return;
  const novoStatus = prompt('Novo status:', status); if (novoStatus === null) return;
  fetch(`/pedidos/${id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ mesa: parseInt(novaMesa), status: novoStatus })
  }).then(res => { if (!res.ok) throw new Error('Erro'); return res.json(); })
    .then(() => { alert('Pedido atualizado!'); location.reload(); })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

<%- include('_footer') %>
